# Harvard API
HARVARD_ART_API_KEY=YOUR_HARVARD_API_KEY
HARVARD_API_BASE_URL=https://api.harvardartmuseums.org

# Ingestion behavior
HARVARD_PAGE_SIZE=100
HARVARD_MAX_PAGES=20
TOP_CLASSIFICATION_LIMIT=12
MAX_ITEMS_PER_ERA=24
INCLUDE_UNKNOWN_ERA=true
APPEND_MODE=true
DEDUPE_BY_ID=true
# AWS
AWS_REGION=eu-west-2
RAW_BUCKET=ham-topic-explorer-raw
CURATED_BUCKET=ham-topic-explorer-curated
RAW_KEY=raw/objects.jsonl
DATASET_KEY=datasets/topic_tree.json
SNS_TOPIC_ARN=
LAMBDA_FUNCTION_NAME=ham-topic-explorer-ingestion
DATASET_FRESHNESS_MAX_HOURS=26
LOCAL_DEMO_DATASET_PATH=frontend/dataset.json

# Minimal admin control plane (shared-secret)
ADMIN_TOKEN=replace-with-strong-random-secret
EVENTBRIDGE_RULE_NAME=ham-topic-explorer-refresh
INGESTION_LAMBDA_NAME=ham-topic-explorer-ingestion
ADMIN_REFRESH_COOLDOWN_SECONDS=300
ADMIN_STATE_KEY=admin/refresh_state.json
